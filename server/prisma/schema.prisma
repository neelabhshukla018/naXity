generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  DRIVER
  RESTAURANT_OWNER
  CITY_OFFICIAL
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model User {
  id            String   @id @default(cuid())

  // Basic Info
  name          String
  email         String   @unique
  phone         String?  @unique
  password      String

  // Profile
  imageUrl      String?
  imagePublicId String?

  bio           String?
  address       String?

  city          String?
  state         String?

  gender        Gender?
  dateOfBirth   DateTime?

  // Authorization
  role          Role     @default(USER)

  // Verification
  isVerified    Boolean  @default(false)

  otp           String?
  otpExpiry     DateTime?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}